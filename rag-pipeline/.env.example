# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# API key — leave blank if LLM_PROVIDER=ollama
# Anthropic: https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=

# Model name (must match provider)
# anthropic → claude-3-5-haiku-20241022
# openai    → gpt-4o-mini
# ollama    → llama3.2
LLM_MODEL=claude-3-5-haiku-20241022

# Sentence-transformers embedding model. Runs locally — no API key needed.
# Downloads to the HuggingFace cache on first run (~90MB), loads from cache after that.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of chunks to retrieve per query
TOP_K=3

# Minimum cosine similarity score (0.0-1.0) a chunk must clear to be used as
# context. Below this, the pipeline returns "I don't know" instead of guessing.
SCORE_THRESHOLD=0.3

# Chunk size in characters for splitting documents before embedding
CHUNK_SIZE=800

# Overlap between adjacent chunks, in characters (must be < CHUNK_SIZE)
CHUNK_OVERLAP=150

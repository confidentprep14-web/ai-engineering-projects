# LLM provider to use for extraction calls: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# API key for the chosen provider.
# anthropic -> https://console.anthropic.com/settings/keys
# openai    -> https://platform.openai.com/api-keys
# ollama    -> leave blank, ollama runs locally with no key
LLM_API_KEY=

# Model name. Must support reliable JSON-following instructions.
# anthropic -> claude-3-5-haiku-20241022
# openai    -> gpt-4o-mini
# ollama    -> llama3.2
LLM_MODEL=claude-3-5-haiku-20241022

# Maximum number of attempts (1 initial call + retries) before extraction
# is given up on and ExtractionError is raised.
MAX_RETRIES=3

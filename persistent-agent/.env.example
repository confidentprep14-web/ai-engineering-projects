# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# API key — leave blank if LLM_PROVIDER=ollama
# Anthropic: https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=

# Model name (must match provider)
# anthropic → claude-3-5-haiku-20241022
# openai    → gpt-4o-mini
# ollama    → llama3.2
LLM_MODEL=claude-3-5-haiku-20241022

# SQLite database path. Created on first run, including parent directories.
MEMORY_DB_PATH=./agent_memory.db

# Number of most recent messages to load as active conversation context
RECENT_MESSAGES_LIMIT=20

# Number of highest-confidence facts to inject into the system prompt
TOP_FACTS_LIMIT=10

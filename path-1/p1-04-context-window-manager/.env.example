# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# API key — leave blank if LLM_PROVIDER=ollama
# Anthropic: https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=

# Model name (must match provider)
# anthropic → claude-3-5-haiku-20241022
# openai    → gpt-4o-mini
# ollama    → llama3.2
LLM_MODEL=claude-3-5-haiku-20241022

# Context window size in tokens (set to match your model, see table below)
# claude-3-5-haiku: 200000  |  gpt-4o-mini: 128000  |  llama3.2: 8192
# Set this conservatively — token counting is an approximation for non-OpenAI
# models (see GUIDE.md) so leave headroom below the model's real limit.
CONTEXT_LIMIT=8192

# Warn when conversation uses this fraction of CONTEXT_LIMIT (0.0-1.0)
WARN_THRESHOLD=0.8

# Strategy to use when the limit is approached: sliding | summarise
CONTEXT_STRATEGY=sliding

# For the summarise strategy: number of most recent turns to keep verbatim
# (everything older than this gets compressed into one summary message)
SUMMARISE_KEEP_RECENT=6

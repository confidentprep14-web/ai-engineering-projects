# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# API key — leave blank if LLM_PROVIDER=ollama
# Anthropic: https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=

# Model name (must match provider)
# anthropic → claude-3-5-haiku-20241022
# openai    → gpt-4o-mini
# ollama    → llama3.2
LLM_MODEL=claude-3-5-haiku-20241022

# Max requests a single client IP may make per rolling 60-second window
RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Cost per 1M tokens (USD) — used to compute per-request cost for /stats
# anthropic claude-3-5-haiku: input=$1.00, output=$5.00
# openai gpt-4o-mini: input=$0.15, output=$0.60
COST_PER_1M_INPUT_TOKENS=1.00
COST_PER_1M_OUTPUT_TOKENS=5.00

# SQLite database path. /data/ is the Docker named volume mount point —
# anything written outside it is lost when the container is recreated.
DATABASE_PATH=/data/chat_requests.db
